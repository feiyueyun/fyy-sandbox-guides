# e2b.Dockerfile — FYY Agent E2B 沙箱模板
#
# 使用方法:
#   1. 将此文件放在项目根目录，命名为 e2b.Dockerfile
#   2. 创建 e2b.toml 配置文件
#   3. 运行: e2b template build
#
# 注意:
#   - 文件名必须为 e2b.Dockerfile（E2B 约定）
#   - Dockerfile 结尾必须是 USER root（E2B 要求）
#   - 不支持 VOLUME、EXPOSE、HEALTHCHECK 指令
#   - 构建上下文大小限制为 100 MB

# ---------------------------------------------------------------------------
# 基础镜像
# ---------------------------------------------------------------------------
# 使用 FYY 沙箱官方镜像
# 生产环境建议固定版本号，如 feiyueyun/fyy-sandbox:1.2.0
FROM feiyueyun/fyy-sandbox:latest

# ---------------------------------------------------------------------------
# 额外系统依赖（按需取消注释）
# ---------------------------------------------------------------------------
# RUN apt-get update && apt-get install -y --no-install-recommends \
#     ffmpeg \
#     && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# 额外 Python 包（按需取消注释）
# ---------------------------------------------------------------------------
# RUN pip install --no-cache-dir pandas numpy

# ---------------------------------------------------------------------------
# 预装自定义技能（按需取消注释）
# ---------------------------------------------------------------------------
# COPY --chown=fyy:fyy ./skills/ /data/fyy/skills/

# ---------------------------------------------------------------------------
# E2B 要求以 root 用户结束 Dockerfile
# ---------------------------------------------------------------------------
# 沙箱启动后由 E2B 运行时管理用户权限
USER root
